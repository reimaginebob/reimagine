# Reimagine local-dev env vars. Copy this file to .env.local and fill in
# the real values. .env.local is gitignored and never committed.
#
# Production values live in the Vercel project settings, not here.

# Neon Postgres (pooled connection string)
DATABASE_URL=

# Resend API key + verified sender. Sender must match a verified domain
# in the Resend dashboard. Example: "Reimagine <hi@send.career.club>".
RESEND_API_KEY=
EMAIL_FROM=

# Base URL the magic-link email points back to. For local dev with
# `vercel dev`, this is usually http://localhost:3000.
MAGIC_LINK_BASE_URL=

# Session cookie config
SESSION_COOKIE_NAME=pe_session
SESSION_DAYS=30

# Vercel Protection Bypass for Automation token (project setting).
# Used by scripts/smoke-preview.mjs to curl preview deployments past
# Vercel's deployment protection. Generate at:
#   Vercel project settings → Deployment Protection →
#   Protection Bypass for Automation.
# At deploy time the same token is exposed as VERCEL_AUTOMATION_BYPASS_SECRET.
# Rotate via the same Vercel setting if leaked.
VERCEL_PROTECTION_BYPASS=
