{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    { "source": "/demo", "destination": "/?demo=true", "statusCode": 302 }
  ],
  "rewrites": [
    { "source": "/auth/verify", "destination": "/api/auth/verify" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/reimagine-user-guide.pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Content-Disposition", "value": "inline; filename=\"reimagine-user-guide.pdf\"" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
