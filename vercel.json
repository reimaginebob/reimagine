{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    { "source": "/demo", "destination": "/?demo=true", "statusCode": 302 }
  ],
  "rewrites": [
    { "source": "/auth/verify", "destination": "/api/auth/verify" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
