.DS_Store

# Local env files (never commit secrets)
.env.local
.env.*.local

# Auto-generated by scripts/build-user-guide.mjs on prebuild
src/data/user-guide-content.js

# Auto-generated by scripts/write-build-meta.mjs on prebuild (stale-build
# self-healing). Both files carry the commit SHA + build timestamp from one
# source of truth; regenerated on every build.
public/version.json
src/build-meta.js

# Corpus fixtures used for prompt testing. Even anonymized, profile content
# is shaped from real beta users; keep local-only. Exception: mockup-profiles.mjs
# is fully constructed (no real-user data) and is tracked for the --p6 / --ab-mockup
# voice harness.
scripts/fixtures/*
!scripts/fixtures/mockup-profiles.mjs
